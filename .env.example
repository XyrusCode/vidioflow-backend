# Application
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=vidioflow

# File Paths
VIDEO_OUTPUT_DIR=/tmp/videos
AUDIO_OUTPUT_DIR=/tmp/audio
FINAL_OUTPUT_DIR=/tmp/output

# FFmpeg (override if not in PATH)
FFMPEG_PATH=ffmpeg
